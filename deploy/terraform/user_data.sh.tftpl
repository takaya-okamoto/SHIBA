#!/bin/bash
# Rendered by Terraform templatefile(): the named placeholders below are substituted at plan time.
# Bash uses $(...) and $VAR (no braces) so Terraform leaves them alone; literal $${ would escape.
set -eu # Lightsail runs user_data under /bin/sh (dash) — NO bash-isms (no `pipefail`/`[[ ]]`/arrays)
exec > /var/log/shiba-bootstrap.log 2>&1

# --- Docker Engine + compose plugin (official repo) ---
export DEBIAN_FRONTEND=noninteractive
# Ubuntu first-boot unattended-upgrades holds the apt lock; WAIT for it instead of failing.
echo 'DPkg::Lock::Timeout "600";' > /etc/apt/apt.conf.d/99lock-timeout
apt-get update -y
apt-get install -y ca-certificates curl git
install -m 0755 -d /etc/apt/keyrings
curl -fsSL https://download.docker.com/linux/ubuntu/gpg -o /etc/apt/keyrings/docker.asc
chmod a+r /etc/apt/keyrings/docker.asc
echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo "$VERSION_CODENAME") stable" \
  > /etc/apt/sources.list.d/docker.list
apt-get update -y
apt-get install -y docker-ce docker-ce-cli containerd.io docker-compose-plugin

# --- App ---
install -d -m 0755 /opt/shiba
CLONE_URL="${repo_url}"
if [ -n "${github_repo_token}" ]; then
  # inject a read-only PAT for private repos (token also lands in instance metadata — see README)
  CLONE_URL="https://x-access-token:${github_repo_token}@$(printf '%s' "${repo_url}" | sed -e 's#^https\?://##')"
fi
if [ -d /opt/shiba/app/.git ]; then
  git -C /opt/shiba/app pull --ff-only
else
  git clone "$CLONE_URL" /opt/shiba/app
fi

# --- Secrets (.env, 0600) ---
# NOTE: these values are baked into Lightsail user_data and tfstate (see README, Gotcha C).
# Bedrock auth = IAM user access keys (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY). The app's
# AnthropicBedrock SDK reads them from the environment (the default AWS credential chain
# prefers env vars), so no ~/.aws files are needed.
umask 077
cat > /opt/shiba/app/.env <<'ENVEOF'
MODEL_PROVIDER=${model_provider}
AWS_REGION=${aws_region}
AWS_ACCESS_KEY_ID=${aws_access_key_id}
AWS_SECRET_ACCESS_KEY=${aws_secret_access_key}
BEDROCK_RESPONSE_MODEL=${bedrock_response_model}
BEDROCK_EXTRACT_MODEL=${bedrock_extract_model}
ANTHROPIC_API_KEY=${anthropic_api_key}
TELEGRAM_BOT_TOKEN=${telegram_bot_token}
TIDB_EXP_EMBED_GEMINI_API_KEY=${gemini_api_key}
TIDB_HOST=${tidb_host}
TIDB_PORT=${tidb_port}
TIDB_USER=${tidb_user}
TIDB_PASSWORD=${tidb_password}
TIDB_DATABASE=${tidb_database}
MEMORY_GIT_REMOTE=${memory_git_remote}
ENVEOF
chmod 600 /opt/shiba/app/.env

# --- Launch only once the TiDB password is present (see Gotcha A) ---
cd /opt/shiba/app
# data/ is a mounted volume written by the container's `node` user (uid 1000). Create it owned by
# that uid up front; otherwise Docker creates it root-owned and the app cannot persist memory or
# the allowlist (writes fail with EACCES, silently caught). See LEARNINGS.
install -d -m 0775 -o 1000 -g 1000 /opt/shiba/app/data
if [ -n "${tidb_password}" ]; then
  docker compose up -d --build
else
  echo "TIDB_PASSWORD empty: skipping 'docker compose up'. Set it (console reset) and re-apply."
fi
