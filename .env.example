# Copy to .env. (Terraform renders this on the Lightsail box; for local dev fill it yourself.)

# --- Messaging (Telegram, long polling — no public endpoint) ---
TELEGRAM_BOT_TOKEN=

# --- Model ---
MODEL_PROVIDER=bedrock        # bedrock (keyless via instance role / aws sso) | anthropic
AWS_REGION=ap-northeast-1
ANTHROPIC_API_KEY=            # only when MODEL_PROVIDER=anthropic
BEDROCK_RESPONSE_MODEL=       # required when MODEL_PROVIDER=bedrock (region inference-profile id)
BEDROCK_EXTRACT_MODEL=

# --- TiDB (derived index) ---
TIDB_HOST=
TIDB_PORT=4000
TIDB_USER=
TIDB_PASSWORD=
TIDB_DATABASE=shiba
TIDB_CA_PATH=/etc/ssl/cert.pem   # system CA bundle (macOS: /etc/ssl/cert.pem); blank to use Node defaults

# --- Embedding (auto-embed via TiDB; default = free managed Titan, no key) ---
EMBED_PROVIDER=tidb-auto                                   # tidb-auto | local
EMBED_MODEL=tidbcloud_free/amazon/titan-embed-text-v2      # gemini/gemini-embedding-001 for prod (BYOK, dim 1536)
EMBED_DIM=1024

# --- Memory (source of truth = Markdown + git) ---
MEMORY_DIR=./data/memory
MEMORY_GIT_REMOTE=            # optional private repo for offsite backup
