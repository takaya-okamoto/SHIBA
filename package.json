{
  "name": "shiba",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "migrate": "tsx src/main.ts migrate",
    "reindex": "tsx src/main.ts reindex",
    "search": "tsx src/main.ts search",
    "eval": "tsx src/main.ts eval",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src",
    "format": "biome format --write src"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.30.2",
    "@anthropic-ai/sdk": "^0.104.1",
    "dotenv": "^16.4.5",
    "grammy": "^1.43.0",
    "mysql2": "^3.11.3",
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.5.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
