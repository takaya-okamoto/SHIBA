# Copy to .env. Get these from the TiDB Cloud console (cluster -> Connect).
# Use a TiDB Cloud Starter (serverless) cluster in AWS Tokyo (ap-northeast-1).
TIDB_HOST=gateway01.ap-northeast-1.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=xxxxxxxx.root
TIDB_PASSWORD=
TIDB_DATABASE=shiba_poc

# Embedding model for auto-embed. DEFAULT = TiDB's FREE managed model — NO API key needed.
# EMBED_DIM must equal the model's output dimension.
#   tidbcloud_free/amazon/titan-embed-text-v2  -> 1024  (free, no key — use this for the PoC)
#   gemini/gemini-embedding-001                -> 1536  (BYOK: set your Gemini key in the TiDB console first)
EMBED_MODEL=tidbcloud_free/amazon/titan-embed-text-v2
EMBED_DIM=1024

# Bench knobs (optional)
FACTS=2000
BENCH_REPS=30
